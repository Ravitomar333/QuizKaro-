<!DOCTYPE html>
<html>
<head>
    <title>Admin Results</title>
    <link rel="stylesheet" href="/css/style3.css">
</head>
<body>

        <nav class="navbar">
  <div class="nav-left">
    <h2>QuizKaro</h2>
  </div>

  <div class="nav-right">
     <a href="/admin">Dashboard</a>
    <a href="/admin/create-quiz">Create Quiz</a>
   
    <a href="/logout" class="logout-btn">Logout</a>
  </div>
</nav>

<div class="container">

    <h2>Quiz Results</h2>

    <div class="quiz-container">

        <% if (results && results.length > 0) { %>

            <% results.forEach(r => { %>

                <div class="quiz-card">

                    <h3>👤 <%= r.userName %></h3>
                    <p>📘 Quiz: <%= r.quizId ? r.quizId.subject : "Deleted Quiz" %></p>
                    <p>📊 Score: <%= r.score %> / <%= r.total %></p>
                    <p>📈 <%= ((r.score / r.total) * 100).toFixed(1) %>%</p>


  <form action="/admin/delete-result/<%= r._id %>" method="POST" 
      onsubmit="return confirm('Are you sure you want to delete this result?')">
    <button type="submit" class="delete-btn">🗑 Delete</button>
</form>
                </div>

            <% }) %>

        <% } else { %>

            <p>No results available</p>

        <% } %>

    </div>

</div>
    <%- include('partials/footer2') %>

</body>
</html>